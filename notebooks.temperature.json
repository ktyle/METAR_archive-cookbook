A0JZXshzjz"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"time_0 = time_1 - timedelta(hours=1)\nYYYY_0 = time_0.strftime(\"%Y\")\nYYYY_1 = time_1.strftime(\"%Y\")\nprint(time_0, time_1)\n# Handle edge case when the two hours straddle the end/beginning of a yearw\nif (YYYY_0 == YYYY_1):\n    URLs = [f'https://data.source.coop/dynamical/asos-parquet/year={YYYY_1}/data.parquet']\nelse:\n    URLs = [f'https://data.source.coop/dynamical/asos-parquet/year={YYYY_0}/data.parquet',\n            f'https://data.source.coop/dynamical/asos-parquet/year={YYYY_1}/data.parquet']\n","key":"wp2Yy6dgEX"},{"type":"outputs","id":"9T1rNpm5AwWzimph--vus","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"2025-12-31 23:00:00 2026-01-01 00:00:00\n"},"key":"tr6H5llK5P"}],"key":"AocRte30Lk"}],"key":"NqxpPfuEE5"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"URLs","key":"GavL876F5v"},{"type":"outputs","id":"8SK8sbjPijIpg_OmeXy47","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":4,"metadata":{},"data":{"text/plain":{"content":"['https://data.source.coop/dynamical/asos-parquet/year=2025/data.parquet',\n 'https://data.source.coop/dynamical/asos-parquet/year=2026/data.parquet']","content_type":"text/plain"}}},"key":"JMkU4C5s77"}],"key":"NQ7qJhOTZh"}],"key":"IDbV0ClAh7"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"df = duckdb.execute(\"\"\"\n    SELECT *\n    FROM read_parquet($1, hive_partitioning=true)\n    WHERE \n---      country = 'FR' AND\n    valid BETWEEN $2 AND $3\n    ORDER BY country\n\"\"\", [URLs, time_0, time_1]).fetchdf()","key":"QwWkkJ5sdg"},{"type":"outputs","id":"8PlSQwTEYs19rz-YNWjnL","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadat