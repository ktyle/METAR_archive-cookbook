kaKRxTQIyq"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"time_0 = time_1 - timedelta(hours=1)\nYYYY_0 = time_0.strftime(\"%Y\")\nYYYY_1 = time_1.strftime(\"%Y\")\nprint(time_0, time_1)\n# Handle edge case when the two hours straddle the end/beginning of a yearw\nif (YYYY_0 == YYYY_1):\n    URLs = [f'https://data.source.coop/dynamical/asos-parquet/year={YYYY_1}/data.parquet']\nelse:\n    URLs = [f'https://data.source.coop/dynamical/asos-parquet/year={YYYY_0}/data.parquet',\n            f'https://data.source.coop/dynamical/asos-parquet/year={YYYY_1}/data.parquet']\n","key":"IrXf0Gzdbm"},{"type":"outputs","id":"2KKFvIiHh2CCTwcuiugA8","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"2025-12-31 23:00:00 2026-01-01 00:00:00\n"},"key":"SNuHtV9sOp"}],"key":"xPXPmrs3eX"}],"key":"HdrwmJZ4OV"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"URLs","key":"FyURIwkbYV"},{"type":"outputs","id":"oWWiMAgEPQe7CoILsgpRW","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":4,"metadata":{},"data":{"text/plain":{"content":"['https://data.source.coop/dynamical/asos-parquet/year=2025/data.parquet',\n 'https://data.source.coop/dynamical/asos-parquet/year=2026/data.parquet']","content_type":"text/plain"}}},"key":"PNmrpFKUGm"}],"key":"D6P5FaWNPP"}],"key":"mhy7oSwSBF"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"df = duckdb.execute(\"\"\"\n    SELECT *\n    FROM read_parquet($1, hive_partitioning=true)\n    WHERE \n---      country = 'FR' AND\n    valid BETWEEN $2 AND $3\n    ORDER BY country\n\"\"\", [URLs, time_0, time_1]).fetchdf()","key":"VBFlPbEDJ6"},{"type":"outputs","id":"bMSToqg_VLwkEd7CRk4SI","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadat